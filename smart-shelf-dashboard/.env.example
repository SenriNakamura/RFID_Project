# Copy this to .env and fill in real values, OR export these in your shell.
# Never commit real credentials.

# === Required for live email sending ===
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (regular Gmail passwords will not work — Google requires an app password
#  when 2FA is enabled, which it should be).
SMTP_USERNAME=smartshelf@ee144.edu
SMTP_PASSWORD=your-app-password-here

# === Optional ===
# Set to "1" to skip real SMTP and just print emails to the Flask console.
# Useful during development when you don't have credentials.
SMTP_DRY_RUN=0

# Path to SQLite DB (defaults to ./smart_shelf.db)
# SHELF_DB_PATH=/var/lib/smartshelf/state.db
